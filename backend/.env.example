# ─── StormWatch backend ───────────────────────────────────────────────
# Copie para .env e preencha. Gere as chaves VAPID com:
#   python -c "from py_vapid import Vapid02; v=Vapid02(); v.generate_keys(); import base64; print(base64.urlsafe_b64encode(v.private_pem()).decode())"
# ou use o script infra/DEPLOY.md (seção Web Push).

# Chaves VAPID para Web Push (base64 url-safe)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@stormwatch.app

# Banco de dados
DATABASE_PATH=./data/stormwatch.db

# Satélite
GOES_BUCKET=noaa-goes19
GOES_PRODUCT=ABI-L2-RRQPEF
GOES_REGION=us-east-1

# Worker
# POLL_INTERVAL_SECONDS: 300 = 5 min (produto novo a cada ~10 min)
POLL_INTERVAL_SECONDS=300
# FRAMES_FOR_MOTION: nº de quadros usados para estimar deslocamento
FRAMES_FOR_MOTION=3

# Limiares de intensidade (mm/h) — moderada / forte / muito forte
RAIN_MODERATE_MMH=2.5
RAIN_HEAVY_MMH=10.0
RAIN_VERY_HEAVY_MMH=50.0

# Janela de análise ao redor do local monitorado (km)
ANALYSIS_RADIUS_KM=120

# CORS (origem do frontend)
CORS_ORIGINS=http://localhost:5173,https://stormwatch.pages.dev
